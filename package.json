{
  "name": "ai-security-gateway",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:gateway": "pnpm --filter gateway dev",
    "dev:console": "pnpm --filter console dev",
    "db:up": "node scripts/db-up.mjs",
    "db:down": "docker compose down",
    "manual:gateway": "pnpm build && pnpm dev:gateway",
    "manual:full": "pnpm build && pnpm dev",
    "manual": "pnpm db:up && pnpm build && pnpm dev:gateway",
    "manual:all": "pnpm db:up && pnpm build && pnpm dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
