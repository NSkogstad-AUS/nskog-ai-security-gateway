PORT=3001
DATABASE_URL=postgres://gateway:gateway_dev@localhost:5432/ai_gateway
LOG_LEVEL=info
POLICY_BACKEND=local
OPA_BASE_URL=http://localhost:8181
OPA_POLICY_PATH=gateway/policy
OPA_TIMEOUT_MS=5000

# Optional ServiceNow write connector (sn_create_incident)
SERVICENOW_ENABLED=false
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_AUTH_MODE=basic
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=
SERVICENOW_TOKEN_URL=
SERVICENOW_SCOPE=

# Optional Splunk HEC exporter
SPLUNK_HEC_ENABLED=false
SPLUNK_HEC_URL=https://splunk.example.com:8088/services/collector/event
SPLUNK_HEC_TOKEN=
SPLUNK_HEC_INDEX=
SPLUNK_HEC_SOURCE=ai-security-gateway
SPLUNK_HEC_SOURCETYPE=agent_security_event
SPLUNK_HEC_HOST=
SPLUNK_HEC_MAX_RETRIES=3
SPLUNK_HEC_RETRY_BASE_DELAY_MS=300
SPLUNK_HEC_TIMEOUT_MS=5000
